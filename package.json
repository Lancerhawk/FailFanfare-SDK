{
  "name": "failfanfare-root",
  "version": "0.1.0",
  "private": true,
  "description": "Root of the FailFanfare project",
  "scripts": {
    "lint": "npm run lint:sdk",
    "lint:sdk": "npm run lint --prefix failfanfare_sdk",
